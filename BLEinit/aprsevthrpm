int getMotorRunPercent() {
  if (!motorTimingActive) return 0;
  unsigned long elapsed = millis() - motorStartTime;
  if (elapsed >= MOTOR_RUN_TIME_MS) return 100;
  return (int)((elapsed * 100UL) / MOTOR_RUN_TIME_MS);
}

