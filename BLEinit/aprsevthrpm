#include <BLEDevice.h>
#include <BLEUtils.h>
#include <BLEServer.h>

#define SERVICE_UUID        "4fafc201-1fb5-459e-8fcc-c5c9c331914b"
#define CHARACTERISTIC_UUID "beb5483e-36e1-4688-b7f5-ea07361b26a8"

// Motor Control Pins
#define IN1 26
#define IN2 27

// Limit Switch Pins (NC switches - using GPIO18 and GPIO19)
#define LIMIT_SWITCH_TOP    19    // Changed from 34 to 19
#define LIMIT_SWITCH_BOTTOM 18    // Changed from 35 to 18

// LED Pin
#define LED_BUILTIN 2

// Motor State Machine
enum MotorState {
  MOTOR_IDLE,
  MOTOR_FORWARD,
  MOTOR_REVERSE
};

MotorState currentState = MOTOR_IDLE;
bool deviceConnected = false;
bool limitTopActive = false;
bool limitBottomActive = false;

// BLE Objects
BLEServer *pServer = nullptr;
BLECharacteristic *pCharacteristic = nullptr;

// Forward declarations
void setMotorState(MotorState state);
void sendStatus();
void checkLimitSwitches();

class MyCharacteristicCallbacks: public BLECharacteristicCallbacks {
    void onWrite(BLECharacteristic *pCharacteristic) {
      String value = pCharacteristic->getValue().c_str();
      
      Serial.print("Command received: ");
      Serial.println(value);
      
      if (value == "start") {
        if (currentState == MOTOR_IDLE) {
          setMotorState(MOTOR_FORWARD);
        }
      }
      else if (value == "stop") {
        if (currentState != MOTOR_IDLE) {
          setMotorState(MOTOR_IDLE);
        }
      }
      else if (value == "reverse") {
        if (currentState == MOTOR_FORWARD) {
          setMotorState(MOTOR_REVERSE);
        }
        else if (currentState == MOTOR_REVERSE) {
          setMotorState(MOTOR_FORWARD);
        }
      }
      else if (value == "status") {
        sendStatus();
      }
    }
};

class MyServerCallbacks: public BLEServerCallbacks {
    void onConnect(BLEServer* pServer) {
      deviceConnected = true;
      Serial.println(" Client connected!");
      sendStatus();
    }
    
    void onDisconnect(BLEServer* pServer) {
      deviceConnected = false;
      Serial.println(" Client disconnected");
      pServer->startAdvertising();
      Serial.println("Advertising restarted - waiting for connection");
    }
};

void checkLimitSwitches() {
  // Read limit switches (HIGH = pressed for NC switches)
  bool topPressed = (digitalRead(LIMIT_SWITCH_TOP) == HIGH);
  bool bottomPressed = (digitalRead(LIMIT_SWITCH_BOTTOM) == HIGH);
  
  // Control LED based on any limit switch press
  if (topPressed || bottomPressed) {
    digitalWrite(LED_BUILTIN, HIGH);
  } else {
    digitalWrite(LED_BUILTIN, LOW);
  }
  
  // Check for state changes and stop motor if needed
  if (topPressed != limitTopActive) {
    limitTopActive = topPressed;
    if (limitTopActive) {
      Serial.println(" TOP LIMIT SWITCH (GPIO19) TRIGGERED!");
      if (currentState == MOTOR_FORWARD) {
        setMotorState(MOTOR_IDLE);
      }
    } else {
      Serial.println("✓ TOP limit switch (GPIO19) released");
    }
  }
  
  if (bottomPressed != limitBottomActive) {
    limitBottomActive = bottomPressed;
    if (limitBottomActive) {
      Serial.println(" BOTTOM LIMIT SWITCH (GPIO18) TRIGGERED!");
      if (currentState == MOTOR_REVERSE) {
        setMotorState(MOTOR_IDLE);
      }
    } else {
      Serial.println("✓ BOTTOM limit switch (GPIO18) released");
    }
  }
}

void setMotorState(MotorState state) {
  // Safety check with limit switches
  if (state == MOTOR_FORWARD && limitTopActive) {
    Serial.println(" Cannot go FORWARD - Top limit switch active!");
    state = MOTOR_IDLE;
  }
  else if (state == MOTOR_REVERSE && limitBottomActive) {
    Serial.println(" Cannot go REVERSE - Bottom limit switch active!");
    state = MOTOR_IDLE;
  }
  
  currentState = state;
  
  switch (currentState) {
    case MOTOR_IDLE:
      Serial.println("Motor: STOPPED");
      digitalWrite(IN1, LOW);
      digitalWrite(IN2, LOW);
      break;
      
    case MOTOR_FORWARD:
      Serial.println("Motor: FORWARD (opening door)");
      digitalWrite(IN1, HIGH);
      digitalWrite(IN2, LOW);
      break;
      
    case MOTOR_REVERSE:
      Serial.println("Motor: REVERSE (closing door)");
      digitalWrite(IN1, LOW);
      digitalWrite(IN2, HIGH);
      break;
  }
  
  sendStatus();
}

void sendStatus() {
  if (deviceConnected && pCharacteristic != nullptr) {
    String status = "STATUS:";
    switch (currentState) {
      case MOTOR_IDLE: status += "IDLE"; break;
      case MOTOR_FORWARD: status += "FORWARD"; break;
      case MOTOR_REVERSE: status += "REVERSE"; break;
    }
    status += ",TOP:";
    status += limitTopActive ? "ACTIVE" : "OK";
    status += ",BOTTOM:";
    status += limitBottomActive ? "ACTIVE" : "OK";
    
    pCharacteristic->setValue(status.c_str());
    pCharacteristic->notify();
    Serial.println("Status sent: " + status);
  }
}

void handleSerialCommands() {
  if (Serial.available()) {
    String command = Serial.readStringUntil('\n');
    command.trim();
    command.toLowerCase();
    
    if (command == "f" || command == "forward") {
      Serial.println("🔧 Manual: FORWARD");
      setMotorState(MOTOR_FORWARD);
    }
    else if (command == "r" || command == "reverse") {
      Serial.println(" Manual: REVERSE");
      setMotorState(MOTOR_REVERSE);
    }
    else if (command == "s" || command == "stop") {
      Serial.println(" Manual: STOP");
      setMotorState(MOTOR_IDLE);
    }
    else if (command == "status") {
      Serial.print("Current state: ");
      switch(currentState) {
        case MOTOR_IDLE: Serial.print("IDLE"); break;
        case MOTOR_FORWARD: Serial.print("FORWARD"); break;
        case MOTOR_REVERSE: Serial.print("REVERSE"); break;
      }
      Serial.print(" | Top limit (GPIO19): ");
      Serial.print(limitTopActive ? "ACTIVE" : "OK");
      Serial.print(" | Bottom limit (GPIO18): ");
      Serial.println(limitBottomActive ? "ACTIVE" : "OK");
    }
    else if (command == "help") {
      Serial.println("\nAvailable commands:");
      Serial.println("  f / forward  - Run motor forward");
      Serial.println("  r / reverse  - Run motor reverse");
      Serial.println("  s / stop     - Stop motor");
      Serial.println("  status       - Show current status");
      Serial.println("  help         - Show this help");
    }
    else if (command.length() > 0) {
      Serial.println("Unknown command. Type 'help' for available commands");
    }
  }
}

void setup() {
  Serial.begin(115200);
  delay(1000);
  
  // Initialize motor pins
  pinMode(IN1, OUTPUT);
  pinMode(IN2, OUTPUT);
  digitalWrite(IN1, LOW);
  digitalWrite(IN2, LOW);
  
  // Initialize LED
  pinMode(LED_BUILTIN, OUTPUT);
  digitalWrite(LED_BUILTIN, LOW);
  
  // Initialize limit switches with internal pull-ups
  pinMode(LIMIT_SWITCH_TOP, INPUT_PULLUP);
  pinMode(LIMIT_SWITCH_BOTTOM, INPUT_PULLUP);
  
  Serial.println("\n==================================");
  Serial.println(" Chicken Door Motor Controller");
  Serial.println("==================================");
  Serial.println("Limit switches (NC type):");
  Serial.println("  - Top switch: GPIO19");
  Serial.println("  - Bottom switch: GPIO18");
  Serial.println("  - LED will light when any limit switch pressed");
  Serial.println("\nSerial commands (type and press Enter):");
  Serial.println("  f / forward, r / reverse, s / stop, status, help");
  
  // Initialize BLE
  BLEDevice::init("Chicken-Door");
  pServer = BLEDevice::createServer();
  pServer->setCallbacks(new MyServerCallbacks());
  
  BLEService *pService = pServer->createService(SERVICE_UUID);
  pCharacteristic = pService->createCharacteristic(
                      CHARACTERISTIC_UUID,
                      BLECharacteristic::PROPERTY_WRITE |
                      BLECharacteristic::PROPERTY_NOTIFY
                    );
  pCharacteristic->setCallbacks(new MyCharacteristicCallbacks());
  
  pService->start();
  
  BLEAdvertising *pAdvertising = BLEDevice::getAdvertising();
  pAdvertising->addServiceUUID(SERVICE_UUID);
  pAdvertising->setScanResponse(true);
  pAdvertising->setMinPreferred(0x06);
  pAdvertising->setMinPreferred(0x12);
  BLEDevice::startAdvertising();
  
  Serial.println("\nBLE Ready - Device: Chicken-Door");
  Serial.println("==================================\n");
}

void loop() {
  checkLimitSwitches();  // Continuously monitor limit switches (also controls LED)
  handleSerialCommands(); // Handle keyboard input
  delay(10);
}
